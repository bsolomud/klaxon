<div class="min-h-full flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="flex justify-center">
      <div class="h-12 w-12 bg-black flex items-center justify-center rounded-xl shadow-lg">
        <span class="text-white font-bold text-xl tracking-tighter italic">Au</span>
      </div>
    </div>
    <h2 class="mt-6 text-center text-2xl font-semibold tracking-tight text-gray-900">
      <%= t(".title") %>
    </h2>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-sm border border-gray-100 sm:rounded-2xl sm:px-10">
      <%= form_with(builder: AuFormBuilder, model: resource, scope: resource_name, url: session_path(resource_name), local: true, class: "space-y-6") do |f| %>
        <div>
          <%= f.label :email, t(".email"), class: "label-input" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "admin@aulabs.dev" %>
        </div>

        <div>
          <%= f.label :password, t(".password"), class: "label-input" %>
          <%= f.password_field :password, autocomplete: "current-password" %>
        </div>

        <div class="flex items-center">
          <%= f.check_box :remember_me, label_text: t(".remember_me") %>
        </div>

        <div>
          <%= f.submit t(".sign_in"), class: "btn-primary" %>
        </div>
      <% end %>
    </div>

    <div class="mt-8 text-center text-[10px] text-gray-400 uppercase tracking-[0.2em]">
      Aulabs © <%= Time.current.year %>
    </div>
  </div>
</div>
