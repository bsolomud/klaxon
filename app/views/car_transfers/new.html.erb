<div class="mb-8">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= t(".subtitle") %></p>
</div>

<div class="max-w-lg">
  <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm mb-6">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-4"><%= t(".car_details") %></h2>
    <dl class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <div>
        <dt class="text-gray-500"><%= t(".make") %></dt>
        <dd class="font-medium text-gray-900"><%= @car.make %></dd>
      </div>
      <div>
        <dt class="text-gray-500"><%= t(".model") %></dt>
        <dd class="font-medium text-gray-900"><%= @car.model %></dd>
      </div>
      <div>
        <dt class="text-gray-500"><%= t(".year") %></dt>
        <dd class="font-medium text-gray-900"><%= @car.year %></dd>
      </div>
      <div class="col-span-2">
        <dt class="text-gray-500"><%= t(".vin") %></dt>
        <dd class="font-mono font-medium text-gray-900"><%= @car.vin %></dd>
      </div>
    </dl>
  </div>

  <%= form_with url: car_transfers_path, method: :post, class: "space-y-4" do |f| %>
    <%= hidden_field_tag "car_transfer[vin]", @car.vin %>
    <p class="text-sm text-gray-600"><%= t(".explanation") %></p>
    <div class="flex gap-3">
      <%= f.submit t(".submit"), class: "btn-primary" %>
      <%= link_to t(".cancel"), cars_path, class: "text-sm font-medium text-gray-500 hover:text-black transition-colors self-center" %>
    </div>
  <% end %>
</div>
