<div class="min-h-full flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <%= render "devise/shared/header" %>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-sm border border-gray-100 sm:rounded-2xl sm:px-10">
      <%= form_with(builder: AuFormBuilder, model: resource, scope: resource_name, url: session_path(resource_name), local: true, class: "space-y-6") do |f| %>
        <div>
          <%= f.label :email, "Корпоративна пошта", class: "label-input" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@aulabs.io" %>
        </div>

        <div>
          <%= f.label :password, "Пароль", class: "label-input" %>
          <%= f.password_field :password, autocomplete: "current-password" %>
        </div>

        <div class="flex items-center justify-between">
          <%= f.check_box :remember_me, label_text: "Запам'ятати мене" %>

          <% if devise_mapping.recoverable? %>
            <div class="text-sm">
              <%= link_to "Забули пароль?", new_password_path(resource_name), class: "font-medium text-gray-500 hover:text-black transition-colors" %>
            </div>
          <% end %>
        </div>

        <div>
          <%= f.submit "Увійти в систему", class: "btn-primary" %>
        </div>
      <% end %>

      <div class="mt-6 border-t border-gray-100 pt-6 text-center text-sm text-gray-500">
        Немає аккаунту?
        <%= link_to "Створити профіль", new_registration_path(resource_name), class: "font-medium text-black hover:underline" %>
      </div>
    </div>

    <div class="mt-8 text-center text-[10px] text-gray-400 uppercase tracking-[0.2em]">
      Aulabs © <%= Time.current.year %>
    </div>
  </div>
</div>

