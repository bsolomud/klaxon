<div class="min-h-full flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <%= render "devise/shared/header" %>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-sm border border-gray-100 sm:rounded-2xl sm:px-10">
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_with(builder: AuFormBuilder, model: resource, scope: resource_name, url: password_path(resource_name), method: :put) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <div>
          <%= f.label :password, class: "label-input inline-flex items-center gap-1" do %>
            <%= t(".new_password") %>
            <% if @minimum_password_length %>
              <span class="text-[11px] lowercase font-normal text-gray-500 tracking-normal">(<%= t(".min_chars", count: @minimum_password_length) %>)</span>
            <% end %>
          <% end %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password" %>
        </div>

        <div>
          <%= f.label :password_confirmation, t(".confirm_password"), class: "label-input" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
        </div>

        <div>
          <%= f.submit t(".change_password"), class: "btn-primary" %>
        </div>
      <% end %>

      <div class="mt-6 border-t border-gray-100 pt-6 text-center text-sm text-gray-500">
        <%= t(".remember_password") %>
        <%= link_to t(".sign_in"), new_session_path(resource_name), class: "font-medium text-black hover:underline" %>
      </div>
    </div>

    <div class="mt-8 text-center text-[10px] text-gray-400 uppercase tracking-[0.2em]">
      Aulabs © <%= Time.current.year %>
    </div>
  </div>
</div>
