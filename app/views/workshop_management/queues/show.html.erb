<%= turbo_stream_from "queue_#{@queue.id}_operators" %>

<div class="mb-8">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-gray-900">
        <%= @queue.service_category&.name || t(".general_queue") %>
      </h1>
      <p class="mt-1 text-sm text-gray-500"><%= l(@queue.date) %></p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <%= queue_status_badge(@queue.status) %>

      <% if @queue.paused? %>
        <%= button_to t(".reopen"),
              open_workshop_management_workshop_queues_path(@workshop, service_category_id: @queue.service_category_id),
              method: :patch,
              class: "btn-primary cursor-pointer" %>
      <% end %>
      <% if @queue.open? %>
        <%= button_to t(".pause"),
              pause_workshop_management_workshop_queue_path(@workshop, @queue),
              method: :patch,
              class: "inline-flex items-center rounded-lg bg-yellow-50 px-3 py-1.5 text-sm font-medium text-yellow-700 hover:bg-yellow-100 transition-colors cursor-pointer" %>
      <% end %>
      <% if @queue.open? || @queue.paused? %>
        <%= button_to t(".close"),
              close_workshop_management_workshop_queue_path(@workshop, @queue),
              method: :patch,
              class: "inline-flex items-center rounded-lg bg-red-50 px-3 py-1.5 text-sm font-medium text-red-700 hover:bg-red-100 transition-colors cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>

<% if @entries.any? %>
  <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-x-auto">
    <table class="w-full min-w-[700px]">
      <thead>
        <tr class="border-b border-gray-100">
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_position") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_driver") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_car") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_status") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_wait") %></th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody id="operator_queue_entries" class="divide-y divide-gray-50">
        <% @entries.each do |entry| %>
          <%= render partial: "workshop_management/queue_entries/queue_entry", locals: { entry: entry } %>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-sm text-gray-500"><%= t(".empty") %></p>
<% end %>

<div class="mt-8">
  <%= link_to t(".back"), workshop_management_workshop_queues_path(@workshop),
        class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
</div>
