<div class="mb-8">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= t(".subtitle") %></p>
</div>

<% if @queues.any? %>
  <div class="space-y-4">
    <% @queues.each do |queue| %>
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-sm font-semibold text-gray-900">
              <%= queue.service_category&.name || t(".general_queue") %>
            </h2>
            <p class="mt-1 text-xs text-gray-500">
              <%= t(".entries_count", count: queue.queue_entries.active.count) %>
            </p>
          </div>
          <div class="flex items-center gap-3">
            <%= queue_status_badge(queue.status) %>
            <%= link_to t(".view"),
                  workshop_management_workshop_queue_path(@workshop, queue),
                  class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-sm text-center">
    <p class="text-sm text-gray-500 mb-4"><%= t(".empty") %></p>
    <%= button_to t(".open_queue"),
          open_workshop_management_workshop_queues_path(@workshop),
          method: :patch,
          class: "btn-primary cursor-pointer" %>
  </div>
<% end %>
