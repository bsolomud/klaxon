<div class="mb-8">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
  <div class="mt-1">
    <%= service_request_status_badge(@service_request.status) %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
      <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
        <div>
          <dt class="text-gray-500"><%= t(".car") %></dt>
          <dd class="mt-0.5 font-medium text-gray-900"><%= @service_request.car.display_name %></dd>
        </div>
        <div>
          <dt class="text-gray-500"><%= t(".service") %></dt>
          <dd class="mt-0.5 font-medium text-gray-900"><%= @service_request.workshop_service_category.service_category.name %></dd>
        </div>
        <div>
          <dt class="text-gray-500"><%= t(".driver") %></dt>
          <dd class="mt-0.5 font-medium text-gray-900"><%= @service_request.car.user.email %></dd>
        </div>
        <div>
          <dt class="text-gray-500"><%= t(".preferred_time") %></dt>
          <dd class="mt-0.5 font-medium text-gray-900"><%= l(@service_request.preferred_time, format: :short) %></dd>
        </div>
        <div>
          <dt class="text-gray-500"><%= t(".price") %></dt>
          <dd class="mt-0.5 font-medium text-gray-900"><%= @service_request.display_price %></dd>
        </div>
        <div>
          <dt class="text-gray-500"><%= t(".created_at") %></dt>
          <dd class="mt-0.5 font-medium text-gray-900"><%= l(@service_request.created_at, format: :short) %></dd>
        </div>
        <div class="col-span-2">
          <dt class="text-gray-500"><%= t(".description") %></dt>
          <dd class="mt-0.5 text-gray-900"><%= simple_format(@service_request.description) %></dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="space-y-3">
    <%# Action buttons based on current status %>
    <% if @service_request.pending? %>
      <%= button_to t(".accept"), accept_workshop_management_workshop_service_request_path(@workshop, @service_request),
            method: :patch,
            params: { lock_version: @service_request.lock_version },
            class: "w-full btn-primary" %>
      <%= button_to t(".reject"), reject_workshop_management_workshop_service_request_path(@workshop, @service_request),
            method: :patch,
            params: { lock_version: @service_request.lock_version },
            class: "w-full rounded-lg border border-red-300 bg-white px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-50 transition-colors cursor-pointer",
            data: { turbo_confirm: t(".reject_confirm") } %>
    <% elsif @service_request.accepted? %>
      <%= button_to t(".start"), start_workshop_management_workshop_service_request_path(@workshop, @service_request),
            method: :patch,
            params: { lock_version: @service_request.lock_version },
            class: "w-full btn-primary" %>
    <% end %>

    <%= link_to t(".back"), workshop_management_workshop_service_requests_path(@workshop),
          class: "block text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
  </div>
</div>
