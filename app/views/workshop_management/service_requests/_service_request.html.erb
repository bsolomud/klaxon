<tr id="<%= dom_id(service_request, :workshop) %>">
  <td class="px-6 py-3 text-sm text-gray-900"><%= service_request.car.display_name %></td>
  <td class="px-6 py-3 text-sm text-gray-600"><%= service_request.workshop_service_category.service_category.name %></td>
  <td class="px-6 py-3"><%= service_request_status_badge(service_request.status) %></td>
  <td class="px-6 py-3 text-sm text-gray-600"><%= l(service_request.preferred_time, format: :short) %></td>
  <td class="px-6 py-3 text-sm text-gray-600 text-right"><%= service_request.display_price %></td>
  <td class="px-6 py-3 text-right">
    <%= link_to t("workshop_management.service_requests.index.view"),
          workshop_management_workshop_service_request_path(service_request.workshop, service_request),
          class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
  </td>
</tr>
