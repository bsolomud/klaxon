<div class="mb-8">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
  <p class="mt-1 text-sm text-gray-500">
    <%= @service_request.workshop.name %> &mdash; <%= @service_request.workshop_service_category.service_category.name %>
  </p>
</div>

<div class="max-w-lg">
  <%= form_with model: @review, url: service_request_review_path(@service_request), class: "space-y-6" do |f| %>
    <% if @review.errors.any? %>
      <div class="rounded-lg bg-red-50 p-4">
        <ul class="list-disc pl-5 text-sm text-red-700">
          <% @review.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="label-input"><%= t(".rating") %></label>
      <div class="flex gap-1 mt-1" data-controller="star-rating">
        <% (1..5).each do |star| %>
          <label class="cursor-pointer">
            <%= f.radio_button :rating, star, class: "hidden", data: { star_rating_target: "input", action: "star-rating#select" } %>
            <svg data-star-rating-target="star" data-value="<%= star %>" class="h-8 w-8 text-gray-300 transition-colors" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <label class="label-input" for="review_body"><%= t(".body") %></label>
      <%= f.text_area :body, rows: 4,
            class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-black focus:ring-black text-sm",
            placeholder: t(".body_placeholder") %>
    </div>

    <div class="flex items-center gap-4">
      <%= f.submit t(".submit"), class: "btn-primary cursor-pointer" %>
      <%= link_to t(".cancel"), service_request_path(@service_request),
            class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
    </div>
  <% end %>
</div>
