<div id="<%= dom_id(service_request) %>">
  <div class="mb-8">
    <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t("service_requests.show.details") %></h1>
    <div class="mt-1">
      <%= service_request_status_badge(service_request.status) %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 text-sm">
          <div>
            <dt class="text-gray-500"><%= t("service_requests.show.workshop") %></dt>
            <dd class="mt-0.5 font-medium text-gray-900">
              <%= link_to service_request.workshop.name, workshop_path(service_request.workshop),
                    class: "hover:text-black hover:underline" %>
            </dd>
          </div>
          <div>
            <dt class="text-gray-500"><%= t("service_requests.show.service") %></dt>
            <dd class="mt-0.5 font-medium text-gray-900"><%= service_request.workshop_service_category.service_category.name %></dd>
          </div>
          <div>
            <dt class="text-gray-500"><%= t("service_requests.show.car") %></dt>
            <dd class="mt-0.5 font-medium text-gray-900">
              <%= link_to service_request.car.display_name, car_path(service_request.car),
                    class: "hover:text-black hover:underline" %>
            </dd>
          </div>
          <div>
            <dt class="text-gray-500"><%= t("service_requests.show.preferred_time") %></dt>
            <dd class="mt-0.5 font-medium text-gray-900"><%= l(service_request.preferred_time, format: :short) %></dd>
          </div>
          <div>
            <dt class="text-gray-500"><%= t("service_requests.show.price") %></dt>
            <dd class="mt-0.5 font-medium text-gray-900"><%= service_request.display_price %></dd>
          </div>
          <div>
            <dt class="text-gray-500"><%= t("service_requests.show.created_at") %></dt>
            <dd class="mt-0.5 font-medium text-gray-900"><%= l(service_request.created_at, format: :short) %></dd>
          </div>
          <div class="col-span-2">
            <dt class="text-gray-500"><%= t("service_requests.show.description") %></dt>
            <dd class="mt-0.5 text-gray-900"><%= simple_format(service_request.description) %></dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="space-y-3">
      <% if service_request.completed? && service_request.review.blank? %>
        <%= link_to t("service_requests.show.leave_review"),
              new_service_request_review_path(service_request),
              class: "block btn-primary text-center" %>
      <% end %>
      <%= link_to t("service_requests.show.back"), service_requests_path,
            class: "block text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
    </div>
  </div>
</div>
