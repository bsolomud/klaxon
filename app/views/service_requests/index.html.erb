<div class="mb-8">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= t(".subtitle") %></p>
</div>

<% if @service_requests.any? %>
  <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-x-auto">
    <table class="w-full min-w-[640px]">
      <thead>
        <tr class="border-b border-gray-100">
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_workshop") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_service") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_status") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_date") %></th>
          <th class="px-6 py-3 text-right text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_price") %></th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @service_requests.each do |sr| %>
          <tr>
            <td class="px-6 py-3 text-sm text-gray-900"><%= sr.workshop.name %></td>
            <td class="px-6 py-3 text-sm text-gray-600"><%= sr.workshop_service_category.service_category.name %></td>
            <td class="px-6 py-3"><%= service_request_status_badge(sr.status) %></td>
            <td class="px-6 py-3 text-sm text-gray-600"><%= l(sr.preferred_time, format: :short) %></td>
            <td class="px-6 py-3 text-sm text-gray-600 text-right"><%= sr.display_price %></td>
            <td class="px-6 py-3 text-right">
              <%= link_to t(".view"), service_request_path(sr),
                    class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state",
    title: t(".empty_title"),
    body: t(".empty"),
    cta_text: t(".find_workshop"),
    cta_url: workshops_path,
    icon: tag.svg(xmlns: "http://www.w3.org/2000/svg", fill: "none", viewBox: "0 0 24 24", "stroke-width": "1.5", stroke: "currentColor", class: "h-12 w-12 mx-auto") {
      tag.path("stroke-linecap": "round", "stroke-linejoin": "round", d: "M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3 1.5 1.5 3-3.75")
    } %>
<% end %>

<%= render "shared/pagy_nav", pagy: @pagy %>
