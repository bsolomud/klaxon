<div class="mb-8">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= @workshop.name %></p>
</div>

<div class="max-w-2xl">
  <%= render "form", service_request: @service_request, workshop: @workshop, cars: @cars, categories: @categories %>
</div>

<div class="mt-6">
  <%= link_to t(".back"), workshop_path(@workshop),
        class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
</div>
