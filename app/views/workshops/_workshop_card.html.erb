<%= link_to workshop_path(workshop),
            class: "group block bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:border-gray-200 transition-all" do %>
  <%# Cover image (16:9 aspect ratio) %>
  <div class="relative aspect-video bg-gray-50">
    <% if workshop.photos.attached? %>
      <%= image_tag workshop.photos.first.variant(resize_to_fill: [400, 225]),
            class: "w-full h-full object-cover",
            alt: workshop.name %>
    <% elsif workshop.logo.attached? %>
      <div class="w-full h-full flex items-center justify-center p-4">
        <%= image_tag workshop.logo, class: "h-full w-auto object-contain" %>
      </div>
    <% else %>
      <div class="w-full h-full flex items-center justify-center">
        <svg class="h-10 w-10 text-gray-200" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
        </svg>
      </div>
    <% end %>

    <%# Rating badge overlay %>
    <% if workshop.review_count > 0 %>
      <div class="absolute top-2 right-2 flex items-center gap-1 bg-white/90 backdrop-blur-sm rounded-full px-2 py-0.5 shadow-sm">
        <svg class="h-3.5 w-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="<%= ApplicationHelper::STAR_SVG_PATH %>" />
        </svg>
        <span class="text-xs font-semibold text-gray-900"><%= workshop.avg_rating %></span>
      </div>
    <% end %>
  </div>

  <div class="p-5">
    <div class="flex items-start justify-between gap-2">
      <h2 class="text-base font-semibold text-gray-900 group-hover:text-black"><%= workshop.name %></h2>
      <% workshop.service_categories.each do |category| %>
        <span class="shrink-0 inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-600">
          <%= category.name %>
        </span>
      <% end %>
    </div>

    <p class="mt-1 text-sm text-gray-500"><%= workshop.city %>, <%= workshop.country %></p>

    <div class="mt-2 flex items-center gap-1.5">
      <% if workshop.review_count > 0 %>
        <div class="flex"><%= star_icons(workshop.avg_rating, size: "h-3.5 w-3.5") %></div>
        <span class="text-xs font-medium text-gray-700"><%= workshop.avg_rating %></span>
        <span class="text-xs text-gray-400">(<%= workshop.review_count %>)</span>
      <% else %>
        <span class="text-xs text-gray-400"><%= t("workshops.index.no_reviews") %></span>
      <% end %>
    </div>

    <div class="mt-2">
      <%= workshop_status_indicator(workshop) %>
    </div>
  </div>
<% end %>
