<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t(".subtitle") %></p>
  </div>

  <% if user_signed_in? %>
    <%= link_to t(".new_workshop"), new_workshop_path, class: "btn-primary !w-auto" %>
  <% end %>
</div>

<%# Filters %>
<% if params[:city].present? || params[:category].present? || params[:country].present? || params[:open_now].present? %>
  <div class="mb-6 flex items-center gap-2 flex-wrap">
    <span class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".filters") %>:</span>
    <% if params[:city].present? %>
      <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
        <%= params[:city] %>
        <%= link_to workshops_path(request.query_parameters.except("city")), class: "text-gray-400 hover:text-gray-600" do %>
          <%= heroicon("x-mark", class: "h-3 w-3") %>
        <% end %>
      </span>
    <% end %>
    <% if params[:country].present? %>
      <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
        <%= params[:country] %>
        <%= link_to workshops_path(request.query_parameters.except("country")), class: "text-gray-400 hover:text-gray-600" do %>
          <%= heroicon("x-mark", class: "h-3 w-3") %>
        <% end %>
      </span>
    <% end %>
    <% if params[:category].present? %>
      <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
        <%= params[:category] %>
        <%= link_to workshops_path(request.query_parameters.except("category")), class: "text-gray-400 hover:text-gray-600" do %>
          <%= heroicon("x-mark", class: "h-3 w-3") %>
        <% end %>
      </span>
    <% end %>
    <% if params[:open_now].present? %>
      <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">
        <%= t(".open_now_filter") %>
        <%= link_to workshops_path(request.query_parameters.except("open_now")), class: "text-green-400 hover:text-green-600" do %>
          <%= heroicon("x-mark", class: "h-3 w-3") %>
        <% end %>
      </span>
    <% end %>
  </div>
<% end %>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @workshops.each do |workshop| %>
    <%= link_to workshop_path(workshop),
                class: "group block bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:border-gray-200 transition-all" do %>
      <% if workshop.logo.attached? %>
        <div class="h-32 bg-gray-50 flex items-center justify-center p-4">
          <%= image_tag workshop.logo, class: "h-full w-auto object-contain" %>
        </div>
      <% else %>
        <div class="h-32 bg-gray-50 flex items-center justify-center">
          <span class="text-3xl font-bold text-gray-200"><%= workshop.name.first(2).upcase %></span>
        </div>
      <% end %>

      <div class="p-5">
        <div class="flex items-start justify-between gap-2">
          <h2 class="text-base font-semibold text-gray-900 group-hover:text-black"><%= workshop.name %></h2>
          <span class="shrink-0 inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-600">
            <%= workshop.service_category.name %>
          </span>
        </div>

        <p class="mt-1 text-sm text-gray-500"><%= workshop.city %>, <%= workshop.country %></p>

        <div class="mt-3 flex items-center gap-2">
          <div class="h-2 w-2 rounded-full shrink-0 <%= workshop.open_now? ? 'bg-green-500' : 'bg-red-500' %>"></div>
          <span class="text-xs text-gray-500"><%= workshop.open_now? ? t(".open_now") : t(".closed_now") %></span>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<% if @workshops.empty? %>
  <div class="text-center py-12">
    <p class="text-sm text-gray-500"><%= t(".empty") %></p>
  </div>
<% end %>
