<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= @workshop.name %></h1>
      <div class="mt-1 flex items-center gap-3">
        <% @workshop.service_categories.each do |category| %>
          <%= link_to category.name,
                      service_category_path(category),
                      class: "inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700 hover:bg-gray-200 transition-colors" %>
        <% end %>
        <%= workshop_status_indicator(@workshop, open_key: "workshops.show.open_now", closed_key: "workshops.show.closed_now") %>
      </div>
    </div>

    <% if user_signed_in? %>
      <div class="flex items-center gap-2">
        <% if @workshop.active? %>
          <% @open_queues.each do |queue| %>
            <%= button_to t(".join_queue"),
                  queue_entries_path(queue_id: queue.id),
                  method: :post,
                  class: "btn-primary cursor-pointer" %>
          <% end %>
          <%= link_to t(".request_service"), new_service_request_path(workshop_id: @workshop.id),
                class: "btn-primary" %>
        <% end %>
        <%= link_to t(".edit"), edit_workshop_path(@workshop), class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
        <%= button_to t(".delete"), workshop_path(@workshop), method: :delete,
              class: "text-sm font-medium text-red-500 hover:text-red-700 transition-colors cursor-pointer",
              data: { turbo_confirm: t(".delete_confirm") } %>
      </div>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <%# Main content %>
  <div class="lg:col-span-2 space-y-6">
    <%# Logo & Photos %>
    <% if @workshop.logo.attached? || @workshop.photos.attached? %>
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <% if @workshop.logo.attached? %>
          <div class="mb-4">
            <%= image_tag @workshop.logo, class: "h-20 w-auto object-contain" %>
          </div>
        <% end %>

        <% if @workshop.photos.attached? %>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <% @workshop.photos.each do |photo| %>
              <%= image_tag photo, class: "w-full h-32 object-cover rounded-lg" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Description %>
    <% if @workshop.description.present? %>
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <h2 class="text-sm font-medium text-gray-900 uppercase tracking-wider mb-3"><%= t(".description") %></h2>
        <p class="text-sm text-gray-600 leading-relaxed"><%= simple_format(@workshop.description) %></p>
      </div>
    <% end %>

    <%# Services & Pricing %>
    <% if @workshop.workshop_service_categories.any? %>
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <h2 class="text-sm font-medium text-gray-900 uppercase tracking-wider mb-4"><%= t(".services") %></h2>

        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="pb-2 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".service_name") %></th>
              <th class="pb-2 text-right text-xs text-gray-400 uppercase tracking-wider"><%= t(".service_price") %></th>
              <th class="pb-2 text-right text-xs text-gray-400 uppercase tracking-wider"><%= t(".service_duration") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% @workshop.workshop_service_categories.each do |wsc| %>
              <tr>
                <td class="py-2.5 text-sm text-gray-900"><%= wsc.service_category.name %></td>
                <td class="py-2.5 text-sm text-gray-600 text-right"><%= wsc.price_display %></td>
                <td class="py-2.5 text-sm text-gray-400 text-right"><%= wsc.duration_display %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# Working Hours %>
    <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
      <h2 class="text-sm font-medium text-gray-900 uppercase tracking-wider mb-4"><%= t(".working_hours") %></h2>

      <div class="space-y-2">
        <% (0..6).each do |day| %>
          <% wh = @working_hours.find { |h| h.day_of_week == day } %>
          <div class="flex items-center justify-between py-1.5 <%= day == Time.current.wday ? 'font-semibold' : '' %>">
            <span class="text-sm text-gray-700"><%= day_name(day) %></span>
            <% if wh.nil? || wh.closed? %>
              <span class="text-sm text-red-500"><%= t(".day_closed") %></span>
            <% else %>
              <span class="text-sm text-gray-600"><%= wh.opens_at.strftime("%H:%M") %> &ndash; <%= wh.closes_at.strftime("%H:%M") %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Sidebar — Contact info %>
  <div class="space-y-6">
    <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
      <h2 class="text-sm font-medium text-gray-900 uppercase tracking-wider mb-4"><%= t(".contact") %></h2>

      <dl class="space-y-3">
        <div>
          <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".phone") %></dt>
          <dd class="mt-0.5 text-sm text-gray-900">
            <%= link_to @workshop.phone, "tel:#{@workshop.phone}", class: "hover:text-black" %>
          </dd>
        </div>

        <% if @workshop.email.present? %>
          <div>
            <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".email") %></dt>
            <dd class="mt-0.5 text-sm text-gray-900">
              <%= mail_to @workshop.email, class: "hover:text-black" %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>

    <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
      <h2 class="text-sm font-medium text-gray-900 uppercase tracking-wider mb-4"><%= t(".location") %></h2>

      <dl class="space-y-3">
        <div>
          <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".address_label") %></dt>
          <dd class="mt-0.5 text-sm text-gray-900"><%= @workshop.address %></dd>
        </div>

        <div>
          <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".city_label") %></dt>
          <dd class="mt-0.5 text-sm text-gray-900">
            <%= link_to @workshop.city, workshops_path(city: @workshop.city), class: "hover:text-black hover:underline" %>
          </dd>
        </div>

        <div>
          <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".country_label") %></dt>
          <dd class="mt-0.5 text-sm text-gray-900"><%= @workshop.country %></dd>
        </div>

        <% if @workshop.latitude.present? && @workshop.longitude.present? %>
          <div>
            <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".coordinates") %></dt>
            <dd class="mt-0.5 text-xs font-mono text-gray-500"><%= @workshop.latitude %>, <%= @workshop.longitude %></dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>
</div>

<div class="mt-8">
  <%= link_to t(".back"), workshops_path, class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
</div>
