<div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= t(".subtitle") %></p>
  </div>
  <%= link_to t(".add_car"), new_car_path, class: "btn-primary" %>
</div>

<% if @cars.any? %>
  <div class="space-y-4">
    <% @cars.each do |car| %>
      <%= link_to car_path(car), class: "block bg-white border border-gray-100 rounded-2xl p-6 shadow-sm hover:border-gray-200 transition-colors" do %>
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-base font-semibold text-gray-900"><%= car.display_name %></h2>
            <div class="mt-1 flex items-center gap-3 text-sm text-gray-500">
              <span><%= car.license_plate %></span>
              <span>&middot;</span>
              <span><%= t("cars.fuel_types.#{car.fuel_type}") %></span>
              <% if car.transmission.present? %>
                <span>&middot;</span>
                <span><%= t("cars.transmissions.#{car.transmission}") %></span>
              <% end %>
            </div>
          </div>
          <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
          </svg>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state",
    title: t(".empty_title"),
    body: t(".empty"),
    cta_text: t(".add_car"),
    cta_url: new_car_path,
    icon: tag.svg(xmlns: "http://www.w3.org/2000/svg", fill: "none", viewBox: "0 0 24 24", "stroke-width": "1.5", stroke: "currentColor", class: "h-12 w-12 mx-auto") {
      tag.path("stroke-linecap": "round", "stroke-linejoin": "round", d: "M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0H21M3.375 14.25h17.25m-17.25 0V4.875c0-.621.504-1.125 1.125-1.125h11.25c.621 0 1.125.504 1.125 1.125v9.375")
    } %>
<% end %>

<%= render "shared/pagy_nav", pagy: @pagy %>
