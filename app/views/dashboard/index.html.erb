<div class="space-y-8">
  <h1 class="text-2xl font-bold"><%= t("dashboard.index.title") %></h1>

  <% if @show_welcome_banner %>
    <div data-controller="dismissable"
         data-dismissable-url-value="<%= onboarding_path(flag: :welcome_dismissed) %>"
         class="relative bg-gradient-to-r from-gray-900 to-gray-700 text-white rounded-2xl p-6 shadow-sm">
      <button data-action="dismissable#dismiss" class="absolute top-3 right-3 text-white/60 hover:text-white" type="button" aria-label="<%= t("dashboard.index.banner_dismiss") %>">
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
        </svg>
      </button>
      <h2 class="text-lg font-semibold"><%= t("dashboard.index.banner_title") %></h2>
      <p class="mt-1 text-sm text-white/80"><%= t("dashboard.index.banner_body") %></p>
    </div>
  <% end %>

  <% unless @checklist_complete %>
    <section class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
      <h2 class="text-base font-semibold text-gray-900 mb-4"><%= t("dashboard.index.checklist_title") %></h2>
      <ul class="space-y-3">
        <% @checklist.each do |item| %>
          <li class="flex items-center gap-3">
            <% if item[:done] %>
              <svg class="h-5 w-5 text-green-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-gray-400 line-through"><%= t("dashboard.index.checklist_#{item[:key]}") %></span>
            <% else %>
              <svg class="h-5 w-5 text-gray-300 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <circle cx="12" cy="12" r="9" />
              </svg>
              <% if item[:path] %>
                <%= link_to t("dashboard.index.checklist_#{item[:key]}"), item[:path], class: "text-sm font-medium text-gray-900 hover:text-blue-600 transition-colors" %>
              <% else %>
                <span class="text-sm text-gray-500"><%= t("dashboard.index.checklist_#{item[:key]}") %></span>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @new_user %>
    <section class="text-center py-12">
      <h2 class="text-xl font-semibold text-gray-900"><%= t("dashboard.index.welcome_title") %></h2>
      <p class="mt-2 text-sm text-gray-500 max-w-md mx-auto"><%= t("dashboard.index.welcome_body") %></p>

      <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <%= link_to new_car_path, class: "bg-white border border-gray-200 rounded-2xl p-6 shadow-sm hover:border-gray-300 transition-colors text-center" do %>
          <svg class="mx-auto h-10 w-10 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0H21M3.375 14.25h17.25m-17.25 0V4.875c0-.621.504-1.125 1.125-1.125h11.25c.621 0 1.125.504 1.125 1.125v9.375" />
          </svg>
          <h3 class="mt-3 font-medium text-gray-900"><%= t("dashboard.index.welcome_add_car") %></h3>
          <p class="mt-1 text-xs text-gray-500"><%= t("dashboard.index.welcome_add_car_hint") %></p>
        <% end %>

        <%= link_to workshops_path, class: "bg-white border border-gray-200 rounded-2xl p-6 shadow-sm hover:border-gray-300 transition-colors text-center" do %>
          <svg class="mx-auto h-10 w-10 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <h3 class="mt-3 font-medium text-gray-900"><%= t("dashboard.index.welcome_find_workshop") %></h3>
          <p class="mt-1 text-xs text-gray-500"><%= t("dashboard.index.welcome_find_workshop_hint") %></p>
        <% end %>

        <%= link_to new_workshop_path, class: "bg-white border border-gray-200 rounded-2xl p-6 shadow-sm hover:border-gray-300 transition-colors text-center" do %>
          <svg class="mx-auto h-10 w-10 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.049.58.025 1.193-.14 1.743" />
          </svg>
          <h3 class="mt-3 font-medium text-gray-900"><%= t("dashboard.index.welcome_register_workshop") %></h3>
          <p class="mt-1 text-xs text-gray-500"><%= t("dashboard.index.welcome_register_workshop_hint") %></p>
        <% end %>
      </div>
    </section>
  <% else %>
    <% if @workshops.any? %>
      <section>
        <h2 class="text-lg font-semibold mb-4"><%= t("dashboard.index.my_workshops") %></h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @workshops.each do |workshop| %>
            <div class="bg-white rounded-lg border border-gray-200 p-4">
              <h3 class="font-medium"><%= workshop.name %></h3>
              <p class="text-sm text-gray-500 mt-1"><%= workshop.city %></p>
              <%= link_to t("dashboard.index.manage"), workshop_management_workshop_dashboard_path(workshop), class: "text-sm text-blue-600 hover:text-blue-800 mt-2 inline-block" %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold"><%= t("dashboard.index.my_cars") %></h2>
        <%= link_to t("dashboard.index.add_car"), new_car_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      <% if @cars.any? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @cars.each do |car| %>
            <div class="bg-white rounded-lg border border-gray-200 p-4">
              <h3 class="font-medium"><%= car.make %> <%= car.model %></h3>
              <p class="text-sm text-gray-500 mt-1"><%= car.year %> &middot; <%= car.license_plate %></p>
              <%= link_to t("dashboard.index.view"), car_path(car), class: "text-sm text-blue-600 hover:text-blue-800 mt-2 inline-block" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500"><%= t("dashboard.index.no_cars") %></p>
      <% end %>
    </section>

    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold"><%= t("dashboard.index.recent_requests") %></h2>
        <%= link_to t("dashboard.index.view_all_requests"), service_requests_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      <% if @service_requests.any? %>
        <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("dashboard.index.col_workshop") %></th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("dashboard.index.col_car") %></th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("dashboard.index.col_status") %></th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("dashboard.index.col_date") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @service_requests.each do |request| %>
                <tr>
                  <td class="px-4 py-3 text-sm"><%= request.workshop.name %></td>
                  <td class="px-4 py-3 text-sm"><%= request.car.make %> <%= request.car.model %></td>
                  <td class="px-4 py-3 text-sm"><%= t("service_requests.statuses.#{request.status}") %></td>
                  <td class="px-4 py-3 text-sm">
                    <%= link_to l(request.created_at, format: :short), service_request_path(request), class: "text-blue-600 hover:text-blue-800" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-gray-500"><%= t("dashboard.index.no_requests") %></p>
      <% end %>
    </section>

    <section class="text-center py-6">
      <%= link_to t("dashboard.index.find_workshop"), workshops_path, class: "btn-primary inline-block px-6 py-3" %>
    </section>
  <% end %>
</div>
