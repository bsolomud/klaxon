<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= @service_category.name %></h1>
      <p class="mt-1 text-sm font-mono text-gray-400"><%= @service_category.slug %></p>
    </div>

    <% if user_signed_in? %>
      <div class="flex items-center gap-2">
        <%= link_to t(".edit"), edit_service_category_path(@service_category), class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
        <%= button_to t(".delete"), service_category_path(@service_category), method: :delete,
              class: "text-sm font-medium text-red-500 hover:text-red-700 transition-colors cursor-pointer",
              data: { turbo_confirm: t(".delete_confirm") } %>
      </div>
    <% end %>
  </div>
</div>

<div class="mb-6">
  <h2 class="text-lg font-semibold text-gray-900"><%= t(".workshops_title") %></h2>
</div>

<% if @workshops.any? %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <%= render partial: "workshops/workshop_card", collection: @workshops, as: :workshop %>
  </div>
<% else %>
  <div class="text-center py-12">
    <p class="text-sm text-gray-500"><%= t(".no_workshops") %></p>
  </div>
<% end %>

<div class="mt-8">
  <%= link_to t(".back"), service_categories_path, class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
</div>
