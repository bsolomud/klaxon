<% if pagy.pages > 1 %>
  <nav class="mt-8 flex items-center justify-center gap-1" aria-label="Pagination">
    <% if pagy.prev %>
      <%= link_to pagy_url_for(pagy, pagy.prev), class: "inline-flex items-center rounded-lg px-3 py-2 text-sm text-gray-500 hover:bg-gray-100 transition-colors", aria: { label: "Previous" } do %>
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" /></svg>
      <% end %>
    <% end %>

    <% pagy.series.each do |item| %>
      <% if item.is_a?(Integer) %>
        <%= link_to item, pagy_url_for(pagy, item), class: "inline-flex items-center rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors" %>
      <% elsif item.is_a?(String) %>
        <span class="inline-flex items-center rounded-lg bg-black px-3 py-2 text-sm font-medium text-white"><%= item %></span>
      <% elsif item == :gap %>
        <span class="inline-flex items-center px-2 py-2 text-sm text-gray-400">&hellip;</span>
      <% end %>
    <% end %>

    <% if pagy.next %>
      <%= link_to pagy_url_for(pagy, pagy.next), class: "inline-flex items-center rounded-lg px-3 py-2 text-sm text-gray-500 hover:bg-gray-100 transition-colors", aria: { label: "Next" } do %>
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
      <% end %>
    <% end %>
  </nav>
<% end %>
