<%
  badge_classes = case workshop.status
  when "pending"   then "bg-yellow-100 text-yellow-800"
  when "active"    then "bg-green-100 text-green-800"
  when "declined"  then "bg-red-100 text-red-800"
  when "suspended" then "bg-gray-100 text-gray-800"
  end
%>
<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= badge_classes %>">
  <%= t("admin.workshops.statuses.#{workshop.status}") %>
</span>
