<div class="mb-8">
  <h1 class="text-2xl font-semibold tracking-tight"><%= t(".title") %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= t(".subtitle") %></p>
</div>

<%# Status filter tabs %>
<div class="mb-6 flex items-center gap-2 flex-wrap">
  <%= link_to t(".filter_all"),
              admin_workshops_path,
              class: "rounded-full px-3 py-1 text-xs font-medium transition-colors #{params[:status].blank? ? 'bg-black text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
  <% Workshop.statuses.each_key do |status| %>
    <%= link_to t(".filter_#{status}"),
                admin_workshops_path(status: status),
                class: "rounded-full px-3 py-1 text-xs font-medium transition-colors #{params[:status] == status ? 'bg-black text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
  <% end %>
</div>

<% if @workshops.any? %>
  <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-100">
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_name") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_city") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_status") %></th>
          <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_created") %></th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @workshops.each do |workshop| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= workshop.name %></td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= workshop.city %></td>
            <td class="px-6 py-4">
              <%= render "admin/workshops/status_badge", workshop: workshop %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= l(workshop.created_at, format: :short) %></td>
            <td class="px-6 py-4 text-right">
              <%= link_to t(".view"), admin_workshop_path(workshop), class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center py-12">
    <p class="text-sm text-gray-500"><%= t(".empty") %></p>
  </div>
<% end %>
