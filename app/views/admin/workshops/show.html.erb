<div class="mb-8" <%= 'data-controller="toggle" data-toggle-target-value="decline-form"'.html_safe if @workshop.pending? %>>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight"><%= @workshop.name %></h1>
      <div class="mt-1 flex items-center gap-2">
        <%= render "admin/workshops/status_badge", workshop: @workshop %>
        <span class="text-sm text-gray-500"><%= @workshop.city %>, <%= @workshop.country %></span>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <% if @workshop.pending? %>
        <%= button_to t(".approve"), approve_admin_workshop_path(@workshop), method: :patch, class: "btn-primary !w-auto cursor-pointer" %>
        <button type="button" data-action="click->toggle#toggle" class="inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 transition-colors cursor-pointer">
          <%= t(".decline") %>
        </button>
      <% end %>

      <% if @workshop.active? %>
        <%= button_to t(".suspend"), suspend_admin_workshop_path(@workshop), method: :patch, class: "inline-flex items-center rounded-lg bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700 transition-colors cursor-pointer", data: { turbo_confirm: t(".suspend_confirm") } %>
      <% end %>
    </div>
  </div>

  <% if @workshop.pending? %>
    <div id="decline-form" class="mt-6 hidden">
      <div class="bg-red-50 border border-red-200 rounded-2xl p-6">
        <%= form_with url: decline_admin_workshop_path(@workshop), method: :patch, class: "space-y-4" do |f| %>
          <label for="decline_reason" class="block text-sm font-medium text-red-800"><%= t(".decline_reason") %></label>
          <textarea name="decline_reason" id="decline_reason" rows="3" class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-red-500 focus:border-red-500 text-sm"></textarea>
          <div class="flex items-center gap-3">
            <%= f.submit t(".confirm_decline"), class: "inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 transition-colors cursor-pointer" %>
            <button type="button" data-action="click->toggle#toggle" class="text-sm text-gray-500 hover:text-gray-700 cursor-pointer"><%= t(".cancel") %></button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<% if @workshop.declined? && @workshop.decline_reason.present? %>
  <div class="mb-6">
    <div class="bg-red-50 border border-red-200 rounded-2xl p-6">
      <h3 class="text-sm font-medium text-red-800 uppercase tracking-wider mb-2"><%= t(".decline_reason") %></h3>
      <p class="text-sm text-red-700"><%= @workshop.decline_reason %></p>
    </div>
  </div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <%# Main content %>
  <div class="lg:col-span-2 space-y-6">
    <%# Workshop details %>
    <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
      <h2 class="text-sm font-medium text-gray-900 uppercase tracking-wider mb-4"><%= t(".details") %></h2>

      <dl class="space-y-3">
        <div>
          <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".phone") %></dt>
          <dd class="mt-0.5 text-sm text-gray-900"><%= @workshop.phone %></dd>
        </div>

        <% if @workshop.email.present? %>
          <div>
            <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".email") %></dt>
            <dd class="mt-0.5 text-sm text-gray-900"><%= @workshop.email %></dd>
          </div>
        <% end %>

        <div>
          <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".address") %></dt>
          <dd class="mt-0.5 text-sm text-gray-900"><%= @workshop.address %>, <%= @workshop.city %>, <%= @workshop.country %></dd>
        </div>

        <% if @workshop.description.present? %>
          <div>
            <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".description") %></dt>
            <dd class="mt-0.5 text-sm text-gray-600"><%= simple_format(@workshop.description) %></dd>
          </div>
        <% end %>

        <div>
          <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".created_at") %></dt>
          <dd class="mt-0.5 text-sm text-gray-900"><%= l(@workshop.created_at, format: :long) %></dd>
        </div>
      </dl>
    </div>

    <%# Service categories %>
    <% if @workshop.service_categories.any? %>
      <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
        <h2 class="text-sm font-medium text-gray-900 uppercase tracking-wider mb-4"><%= t(".services") %></h2>
        <div class="flex flex-wrap gap-2">
          <% @workshop.service_categories.each do |category| %>
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700"><%= category.name %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Sidebar — Owner info %>
  <div class="space-y-6">
    <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
      <h2 class="text-sm font-medium text-gray-900 uppercase tracking-wider mb-4"><%= t(".owner") %></h2>

      <% if @owner %>
        <dl class="space-y-3">
          <% if @owner.full_name.present? %>
            <div>
              <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".owner_name") %></dt>
              <dd class="mt-0.5 text-sm text-gray-900"><%= @owner.full_name %></dd>
            </div>
          <% end %>
          <div>
            <dt class="text-xs text-gray-400 uppercase tracking-wider"><%= t(".owner_email") %></dt>
            <dd class="mt-0.5 text-sm text-gray-900"><%= @owner.email %></dd>
          </div>
        </dl>
      <% else %>
        <p class="text-sm text-gray-500"><%= t(".no_owner") %></p>
      <% end %>
    </div>
  </div>
</div>

<div class="mt-8">
  <%= link_to t(".back"), admin_workshops_path, class: "text-sm font-medium text-gray-500 hover:text-black transition-colors" %>
</div>
