<div class="mb-8">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900"><%= t(".title") %></h1>
  <p class="mt-1 text-sm text-gray-500"><%= t(".subtitle") %></p>
</div>

<div class="mb-6 flex gap-2">
  <%= link_to t(".filter_all"), admin_reviews_path,
        class: "px-3 py-1.5 text-xs font-medium rounded-full #{params[:status].blank? ? 'bg-black text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'} transition-colors" %>
  <% %w[published hidden flagged].each do |status| %>
    <%= link_to t(".filter_#{status}"), admin_reviews_path(status: status),
          class: "px-3 py-1.5 text-xs font-medium rounded-full #{params[:status] == status ? 'bg-black text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'} transition-colors" %>
  <% end %>
</div>

<% if @reviews.any? %>
  <div class="overflow-x-auto">
  <table class="w-full min-w-[800px]">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="pb-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_workshop") %></th>
        <th class="pb-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_user") %></th>
        <th class="pb-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_rating") %></th>
        <th class="pb-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_body") %></th>
        <th class="pb-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_status") %></th>
        <th class="pb-3 text-left text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_date") %></th>
        <th class="pb-3 text-right text-xs text-gray-400 uppercase tracking-wider"><%= t(".col_actions") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @reviews.each do |review| %>
        <tr>
          <td class="py-3 text-sm text-gray-900"><%= review.workshop.name %></td>
          <td class="py-3 text-sm text-gray-600"><%= review.user.email %></td>
          <td class="py-3 text-sm">
            <div class="flex"><%= star_icons(review.rating) %></div>
          </td>
          <td class="py-3 text-sm text-gray-600 max-w-xs truncate"><%= review.body %></td>
          <td class="py-3 text-sm">
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
              <%= case review.status
                  when 'published' then 'bg-green-100 text-green-700'
                  when 'hidden' then 'bg-gray-100 text-gray-600'
                  when 'flagged' then 'bg-red-100 text-red-700'
                  end %>">
              <%= t("admin.reviews.statuses.#{review.status}") %>
            </span>
          </td>
          <td class="py-3 text-sm text-gray-400"><%= l(review.created_at, format: :short) %></td>
          <td class="py-3 text-right">
            <% if review.published? || review.flagged? %>
              <%= button_to t(".hide"), admin_review_path(review, status: :hidden),
                    method: :patch,
                    class: "text-xs font-medium text-red-600 hover:text-red-800 cursor-pointer" %>
            <% end %>
            <% if review.hidden? %>
              <%= button_to t(".unhide"), admin_review_path(review, status: :published),
                    method: :patch,
                    class: "text-xs font-medium text-green-600 hover:text-green-800 cursor-pointer" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
<% else %>
  <div class="text-center py-12">
    <p class="text-sm text-gray-500"><%= t(".empty") %></p>
  </div>
<% end %>
