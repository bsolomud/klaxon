<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "AULABS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="AULABS">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full antialiased font-sans">
    <% if devise_controller? %>
      <%# Для логіну: чистий екран без обмежень контейнера %>
      <main class="h-full">
        <%= yield %>
      </main>
    <% else %>
      <%# Для внутрішніх сторінок: стандартна сітка %>
      <header class="bg-white border-b border-gray-200" data-controller="toggle">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex h-16 items-center justify-between">
          <div class="font-bold tracking-tighter text-xl">
            <%= link_to "AULABS", root_path, class: "text-black no-underline" %>
          </div>
          <% if user_signed_in? %>
            <%# Desktop nav %>
            <nav class="hidden sm:flex items-center gap-6">
              <%= link_to t("layouts.application.nav.workshops"), workshops_path, class: "text-sm text-gray-600 hover:text-black" %>
              <%= link_to t("layouts.application.nav.my_cars"), cars_path, class: "text-sm text-gray-600 hover:text-black" %>
              <%= link_to t("layouts.application.nav.my_requests"), service_requests_path, class: "text-sm text-gray-600 hover:text-black" %>
              <% if current_user.workshops.exists? %>
                <%= link_to t("layouts.application.nav.my_workshops"), my_workshops_path, class: "text-sm text-gray-600 hover:text-black" %>
              <% end %>
              <%= render "shared/notifications_bell" %>
              <%= button_to t("layouts.application.sign_out"), destroy_user_session_path, method: :delete, class: "text-sm text-gray-500 hover:text-black" %>
            </nav>

            <%# Mobile hamburger + bell %>
            <div class="flex sm:hidden items-center gap-3">
              <%= render "shared/notifications_bell" %>
              <button data-action="toggle#toggle" data-toggle-target-value="mobile-nav" type="button" class="text-gray-600 hover:text-black" aria-label="Menu">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
              </button>
            </div>
          <% end %>
        </div>

        <% if user_signed_in? %>
          <%# Mobile nav dropdown %>
          <nav id="mobile-nav" class="hidden sm:hidden border-t border-gray-100 px-4 pb-4 pt-2 space-y-1">
            <%= link_to t("layouts.application.nav.workshops"), workshops_path, class: "block rounded-lg px-3 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
            <%= link_to t("layouts.application.nav.my_cars"), cars_path, class: "block rounded-lg px-3 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
            <%= link_to t("layouts.application.nav.my_requests"), service_requests_path, class: "block rounded-lg px-3 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
            <% if current_user.workshops.exists? %>
              <%= link_to t("layouts.application.nav.my_workshops"), my_workshops_path, class: "block rounded-lg px-3 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
            <% end %>
            <%= button_to t("layouts.application.sign_out"), destroy_user_session_path, method: :delete, class: "block w-full text-left rounded-lg px-3 py-2 text-sm text-gray-500 hover:bg-gray-100" %>
          </nav>
        <% end %>
      </header>

      <main class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <%= yield %>
      </main>
    <% end %>

    <%= render "shared/flash_messages" %>
  </body>
</html>
