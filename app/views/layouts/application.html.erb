<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "AULABS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="AULABS">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full antialiased font-sans">
    <% if devise_controller? %>
      <%# Для логіну: чистий екран без обмежень контейнера %>
      <main class="h-full">
        <%= yield %>
      </main>
    <% else %>
      <%# Для внутрішніх сторінок: стандартна сітка %>
      <header class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex h-16 items-center justify-between">
          <div class="font-bold tracking-tighter text-xl">
            <%= link_to "AULABS", root_path, class: "text-black no-underline" %>
          </div>
          <% if user_signed_in? %>
            <nav class="flex items-center gap-6">
              <%= link_to t("layouts.application.nav.workshops"), workshops_path, class: "text-sm text-gray-600 hover:text-black" %>
              <%= link_to t("layouts.application.nav.my_cars"), cars_path, class: "text-sm text-gray-600 hover:text-black" %>
              <%= link_to t("layouts.application.nav.my_requests"), service_requests_path, class: "text-sm text-gray-600 hover:text-black" %>
              <% if current_user.workshops.exists? %>
                <%= link_to t("layouts.application.nav.my_workshops"), my_workshops_path, class: "text-sm text-gray-600 hover:text-black" %>
              <% end %>
              <%= button_to t("layouts.application.sign_out"), destroy_user_session_path, method: :delete, class: "text-sm text-gray-500 hover:text-black" %>
            </nav>
          <% end %>
        </div>
      </header>

      <main class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <%= yield %>
      </main>
    <% end %>

    <%= render "shared/flash_messages" %>
  </body>
</html>
